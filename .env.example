# Firebase — انسخ إلى .env.local محلياً
# على Vercel: Settings → Environment Variables → Production + Preview + Development
# ثم Redeploy (متغيرات NEXT_PUBLIC_* تُدمَج وقت البناء)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Firebase Admin — مطلوب لإدارة المستخدمين (تغيير كلمة المرور / الحذف)
# من Firebase Console → Project Settings → Service accounts → Generate new private key
# الصق محتوى JSON كسطر واحد في المتغير التالي (محلياً وعلى Vercel)
FIREBASE_SERVICE_ACCOUNT_JSON=
